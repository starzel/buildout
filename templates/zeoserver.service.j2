[Unit]
Description={{ name }}
After=network.target
PartOf={{ parts.site_unit.name }}.service
ReloadPropagatedFrom={{ parts.site_unit.name }}.service

[Service]
Type=simple
WorkingDirectory={{ parts.buildout.directory }}
ExecStart={{ parts.site_unit.run_sh }} {{ parts.buildout['bin-directory'] }}/zeoserver fg
LimitNOFILE=64000
LimitNPROC=64173
LimitSIGPENDING=64173
PermissionsStartOnly=true
Restart=on-failure
