[Unit]
Description={{ name }}
After={{ parts.site_unit.zeoserver_name }}.service
PartOf={{ parts.site_unit.name }}.service
ReloadPropagatedFrom={{ parts.site_unit.name }}.service

[Service]
Type=simple
WorkingDirectory={{ parts.buildout.directory }}
ExecStart={{ parts.site_unit.run_sh }} {{ parts.buildout['bin-directory'] }}/%i fg
LimitNOFILE=64000
LimitNPROC=64173
LimitSIGPENDING=64173
PermissionsStartOnly=true
MemoryMax=1.5G
Restart=on-failure
